# Default mode when you do not pass --mode.
# Allowed values: paper, live
ALPACA_DEFAULT_MODE=paper

# Paper credentials
ALPACA_PAPER_API_KEY=your_paper_key
ALPACA_PAPER_SECRET_KEY=your_paper_secret

# Live credentials
ALPACA_LIVE_API_KEY=your_live_key
ALPACA_LIVE_SECRET_KEY=your_live_secret

# Optional backward-compatible single-pair fallback.
# These are only used if the mode-specific variables above are missing.
# ALPACA_API_KEY=your_key
# ALPACA_SECRET_KEY=your_secret
